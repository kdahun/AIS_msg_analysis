# 이 파일을 secrets.toml 로 복사한 뒤 실제 값으로 채우세요.
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# secrets.toml 은 .gitignore 로 커밋에서 제외됩니다(비밀번호 보호).
# 이 .example 파일만 저장소에 포함되어 새 PC 세팅용 템플릿 역할을 합니다.
[postgres]
host = "localhost"      # DB 가 다른 PC/도커에 있으면 그 IP 로 변경
port = 5432
user = "sim_user"
password = "여기에_비밀번호"
dbname = "ais_analysis_db"
